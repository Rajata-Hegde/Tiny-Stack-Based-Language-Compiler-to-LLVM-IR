// Temperature Converter - Demonstrating type conversions (i2f, f2i)
// Convert between Celsius and Fahrenheit

// Test 1: Celsius to Fahrenheit
// Formula: F = (C * 9/5) + 32

0 celsius_int =
celsius_int i2f celsius =  // Convert to float

celsius 9 i2f * 5 i2f / 32 i2f + fahrenheit =

fahrenheit print

// Test 2: Another conversion
100 celsius_int =
celsius_int i2f celsius =

celsius 9 i2f * 5 i2f / 32 i2f + fahrenheit =

fahrenheit print

// Test 3: Fahrenheit to Celsius
// Formula: C = (F - 32) * 5/9

86.0 fahrenheit =
fahrenheit 32 i2f - 5 i2f * 9 i2f / celsius =

celsius print

// Test 4: Back to integer
celsius f2i celsius_int =
celsius_int print
